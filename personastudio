<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Magic Plum Company — Persona Studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #fff8fd;
      --bg-soft: #fff0f8;
      --surface: rgba(255,255,255,0.94);
      --surface-2: #fff6fb;
      --text: #6b4b67;
      --muted: #9b7f98;
      --primary: #ff74ba;
      --primary-strong: #ff4ea6;
      --lavender: #d8c4ff;
      --mint: #ccf5e7;
      --peach: #ffe1cc;
      --lemon: #fff4b8;
      --border: #ffd8eb;
      --shadow: 0 12px 30px rgba(255, 116, 186, 0.14);
      --radius: 22px;
      --max-width: 1180px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Quicksand', system-ui, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 10% 10%, rgba(255, 205, 233, 0.85), transparent 16%),
        radial-gradient(circle at 90% 12%, rgba(216, 196, 255, 0.75), transparent 15%),
        radial-gradient(circle at 82% 80%, rgba(204, 245, 231, 0.75), transparent 16%),
        linear-gradient(180deg, #fffaff 0%, #fff3fa 100%);
      line-height: 1.65;
    }

    .container {
      width: min(calc(100% - 2rem), var(--max-width));
      margin: 0 auto;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(255, 248, 253, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 0;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--primary-strong);
      font-family: 'Fredoka', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
    }

    .brand-badge {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      background: linear-gradient(135deg, #ffd1ea, #e2d2ff, #d7fff2);
      border: 2px solid #fff;
      box-shadow: var(--shadow);
    }

    .nav-links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .nav-links a,
    .footer-links a,
    .mini-link,
    .tab {
      text-decoration: none;
      color: var(--text);
      padding: 0.65rem 0.95rem;
      border-radius: 999px;
      background: rgba(255,255,255,0.92);
      border: 1px solid var(--border);
      font-weight: 700;
      transition: transform 0.15s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      cursor: pointer;
    }

    .nav-links a:hover,
    .footer-links a:hover,
    .mini-link:hover,
    .tab:hover,
    .btn:hover {
      transform: translateY(-2px);
    }

    .hero {
      padding: 4rem 0 2.5rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.2rem;
      align-items: center;
    }

    .bubble-label {
      display: inline-block;
      background: #fff;
      border: 2px solid var(--border);
      color: var(--primary-strong);
      border-radius: 999px;
      padding: 0.55rem 0.9rem;
      font-size: 0.95rem;
      font-weight: 700;
      box-shadow: var(--shadow);
      margin-bottom: 1rem;
    }

    h1, h2, h3, h4 {
      margin-top: 0;
      font-family: 'Fredoka', sans-serif;
      line-height: 1.08;
    }

    h1 {
      font-size: clamp(2.6rem, 6vw, 4.8rem);
      color: var(--primary-strong);
      margin-bottom: 1rem;
    }

    h2 {
      font-size: clamp(2rem, 4vw, 3rem);
      color: var(--primary-strong);
      margin-bottom: 0.65rem;
    }

    .gradient-text {
      background: linear-gradient(135deg, #ff63b1, #b88dff 55%, #ff94cb);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    p,
    .hero-copy p,
    .section-head p,
    .panel p,
    .builder-card p,
    .preview-card p,
    .package-card p,
    .footer,
    label,
    .result-line,
    .chip,
    .tiny-note {
      color: var(--muted);
    }

    .hero-actions,
    .tab-row,
    .chip-row,
    .button-row,
    .palette-row,
    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .hero-actions {
      margin-top: 1.4rem;
    }

    .btn {
      display: inline-block;
      text-decoration: none;
      padding: 0.9rem 1.2rem;
      border-radius: 999px;
      font-weight: 700;
      border: 2px solid var(--border);
      transition: transform 0.15s ease;
      cursor: pointer;
      font-family: inherit;
      font-size: 1rem;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
      color: white;
      border-color: transparent;
      box-shadow: var(--shadow);
    }

    .btn-secondary {
      background: white;
      color: var(--primary-strong);
    }

    .hero-panel,
    .panel,
    .builder-card,
    .preview-card,
    .package-card,
    .cta-box {
      background: rgba(255,255,255,0.92);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .hero-panel {
      padding: 1rem;
      background: linear-gradient(180deg, #fffdfd, #fff6fb);
    }

    .hero-art {
      min-height: 430px;
      padding: 1.2rem;
      border-radius: 20px;
      border: 2px dashed #ffc8e4;
      background:
        radial-gradient(circle at 25% 25%, rgba(255,255,255,0.95), transparent 14%),
        radial-gradient(circle at 74% 24%, rgba(255, 220, 240, 0.95), transparent 15%),
        radial-gradient(circle at 20% 80%, rgba(216, 196, 255, 0.65), transparent 17%),
        linear-gradient(180deg, #fff9fd 0%, #fff0f8 100%);
      position: relative;
      overflow: hidden;
      display: grid;
      align-content: space-between;
    }

    .floating {
      position: absolute;
      font-size: 1.3rem;
      opacity: 0.9;
    }

    .floating.one { top: 18px; left: 22px; }
    .floating.two { top: 28px; right: 22px; }
    .floating.three { bottom: 24px; left: 26px; }
    .floating.four { bottom: 24px; right: 28px; }
    .floating.five { top: 45%; left: 12px; }
    .floating.six { top: 48%; right: 12px; }

    .persona-card {
      width: min(100%, 340px);
      margin: 1rem auto;
      background: rgba(255,255,255,0.96);
      border: 2px solid var(--border);
      border-radius: 26px;
      padding: 1rem;
      text-align: center;
    }

    .avatar {
      width: 146px;
      height: 146px;
      margin: 0 auto 1rem;
      border-radius: 50%;
      background: linear-gradient(180deg, #ffe5f3 0%, #ffd6eb 100%);
      border: 2px solid #ffc2df;
      position: relative;
    }

    .avatar::before,
    .avatar::after {
      content: '';
      position: absolute;
      top: 58px;
      width: 18px;
      height: 26px;
      border-radius: 50%;
      background: #775c83;
    }

    .avatar::before { left: 42px; }
    .avatar::after { right: 42px; }

    .avatar span {
      position: absolute;
      left: 50%;
      bottom: 28px;
      width: 22px;
      height: 12px;
      transform: translateX(-50%);
      border-bottom: 3px solid #775c83;
      border-radius: 0 0 14px 14px;
    }

    .persona-name {
      color: var(--primary-strong);
      font-size: 1.35rem;
      margin-bottom: 0.35rem;
    }

    .palette-row {
      justify-content: center;
      margin-top: 0.9rem;
    }

    .swatch {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 2px solid #fff;
      box-shadow: var(--shadow);
    }

    .stats-grid,
    .builder-grid,
    .preview-grid,
    .package-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .stats-grid {
      margin-top: 1rem;
    }

    .stat {
      padding: 0.95rem;
      background: white;
      border: 2px solid var(--border);
      border-radius: 18px;
      text-align: center;
    }

    .stat strong {
      display: block;
      color: var(--primary-strong);
      font-size: 1.45rem;
      font-family: 'Fredoka', sans-serif;
    }

    section {
      padding: 1rem 0 3rem;
    }

    .section-head {
      text-align: center;
      margin-bottom: 1.2rem;
    }

    .panel,
    .builder-card,
    .preview-card,
    .package-card,
    .cta-box {
      padding: 1.25rem;
      background: linear-gradient(180deg, #fff, #fff6fb);
    }

    .icon {
      width: 58px;
      height: 58px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, #ffd9ec, #e5d8ff, #dafbee);
      border: 2px solid #fff;
      box-shadow: var(--shadow);
      font-size: 1.4rem;
      margin-bottom: 0.9rem;
    }

    .builder-layout {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 1rem;
      align-items: start;
    }

    .builder-card h3,
    .preview-card h3,
    .package-card h3,
    .cta-box h2,
    .panel h3 {
      color: var(--primary-strong);
      margin-bottom: 0.5rem;
    }

    .field {
      margin-bottom: 1rem;
    }

    .field label {
      display: block;
      margin-bottom: 0.45rem;
      font-weight: 700;
      color: var(--text);
    }

    input,
    textarea,
    select {
      width: 100%;
      border: 2px solid var(--border);
      border-radius: 16px;
      padding: 0.85rem 0.95rem;
      font: inherit;
      color: var(--text);
      background: white;
      outline: none;
    }

    textarea {
      min-height: 104px;
      resize: vertical;
    }

    input:focus,
    textarea:focus,
    select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(255, 116, 186, 0.12);
    }

    .chip-row {
      margin-top: 0.6rem;
    }

    .chip {
      padding: 0.45rem 0.8rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: white;
      font-weight: 700;
    }

    .tab-row {
      margin-bottom: 1rem;
    }

    .tab.active {
      background: linear-gradient(135deg, #ffd9ec, #eadfff);
      color: var(--primary-strong);
      border-color: #f6c4df;
    }

    .preview-card {
      position: sticky;
      top: 96px;
    }

    .preview-banner {
      padding: 1rem;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(255, 158, 207, 0.35), rgba(216, 196, 255, 0.45), rgba(204, 245, 231, 0.45));
      border: 2px dashed rgba(255, 116, 186, 0.28);
      margin-bottom: 1rem;
    }

    .preview-name {
      font-family: 'Fredoka', sans-serif;
      font-size: 1.6rem;
      color: var(--primary-strong);
      margin-bottom: 0.2rem;
    }

    .preview-handle {
      font-weight: 700;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    .result-box {
      background: white;
      border: 2px solid var(--border);
      border-radius: 18px;
      padding: 1rem;
      margin-bottom: 0.9rem;
    }

    .result-label {
      font-family: 'Fredoka', sans-serif;
      color: var(--primary-strong);
      margin-bottom: 0.35rem;
    }

    .result-line strong {
      color: var(--text);
    }

    .preview-grid {
      margin-top: 1rem;
    }

    .mini-card {
      background: white;
      border: 2px solid var(--border);
      border-radius: 18px;
      padding: 1rem;
    }

    .mini-card h4 {
      color: var(--primary-strong);
      margin-bottom: 0.4rem;
    }

    .package-meta {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.8rem;
    }

    .package-meta span {
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      color: var(--primary-strong);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .cta-box {
      text-align: center;
      padding: 2rem;
    }

    .footer {
      border-top: 1px solid var(--border);
      padding: 1.5rem 0 2rem;
      text-align: center;
      background: rgba(255,255,255,0.45);
    }

    .footer-links {
      justify-content: center;
      margin-top: 1rem;
    }

    @media (max-width: 980px) {
      .hero-grid,
      .builder-layout,
      .builder-grid,
      .preview-grid,
      .package-grid,
      .stats-grid {
        grid-template-columns: 1fr;
      }

      .preview-card {
        position: static;
      }
    }

    @media (max-width: 640px) {
      .nav-inner {
        flex-direction: column;
        align-items: flex-start;
      }

      .hero-art {
        min-height: auto;
      }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <a class="brand" href="#">
        <span class="brand-badge">🎭</span>
        <span>Persona Studio</span>
      </a>
      <div class="nav-links">
        <a href="#">Overview</a>
        <a href="#">Builder</a>
        <a href="#">Preview</a>
        <a href="#">Packages</a>
        <a href="#">Start</a>
      </div>
    </div>
  </nav>

  <header class="hero container">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="bubble-label">🎀 A Magic Plum Company creation tool</span>
        <h1><span class="gradient-text">Build a full online persona</span><br>that feels like you.</h1>
        <p>
          Persona Studio is a soft-tech page for shaping an online self from scratch. It helps turn random ideas,
          aesthetics, colours, moods, usernames, and creator goals into one clear persona with a look, tone, and vibe.
        </p>
        <p>
          Use it as a concept page, an intake experience, or the start of a future interactive builder for your whole branch.
        </p>
        <div class="hero-actions">
          <a href="#" class="btn btn-primary">Start Building</a>
          <a href="#" class="btn btn-secondary">Open Placeholder Preview</a>
        </div>
      </div>

      <div class="hero-panel">
        <div class="hero-art">
          <span class="floating one">✨</span>
          <span class="floating two">🎀</span>
          <span class="floating three">💖</span>
          <span class="floating four">☁️</span>
          <span class="floating five">🌸</span>
          <span class="floating six">⭐</span>

          <div class="persona-card">
            <div class="avatar"><span></span></div>
            <div class="persona-name" id="heroPersonaName">Plumwave</div>
            <p id="heroPersonaMood">dreamy • kind • expressive • soft-tech</p>
            <div class="palette-row">
              <span class="swatch" style="background:#ff9ecf"></span>
              <span class="swatch" style="background:#d8c4ff"></span>
              <span class="swatch" style="background:#ccf5e7"></span>
              <span class="swatch" style="background:#ffe1cc"></span>
            </div>
            <a href="#" class="mini-link">Placeholder Persona Card</a>
          </div>

          <div class="stats-grid">
            <div class="stat">
              <strong id="stat-traits">0</strong>
              <span>persona traits</span>
            </div>
            <div class="stat">
              <strong id="stat-systems">0</strong>
              <span>style systems</span>
            </div>
            <div class="stat">
              <strong id="stat-ideas">0</strong>
              <span>identity ideas</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section>
    <div class="container">
      <div class="section-head">
        <h2>What Persona Studio is for</h2>
        <p>
          This page is made for creators, projects, online communities, and internet-first people who want a full persona instead of random disconnected branding.
        </p>
      </div>
      <div class="builder-grid">
        <article class="builder-card">
          <div class="icon">🪞</div>
          <h3>Find your vibe</h3>
          <p>Shape the emotional feel of your persona with mood words, comfort levels, style direction, and internet energy.</p>
        </article>
        <article class="builder-card">
          <div class="icon">🎨</div>
          <h3>Choose your look</h3>
          <p>Build a visual system with colours, aesthetics, profile styling, and a recognizable online presentation.</p>
        </article>
        <article class="builder-card">
          <div class="icon">💬</div>
          <h3>Define your voice</h3>
          <p>Create a tone for bios, captions, intros, profile text, and how your presence should sound across platforms.</p>
        </article>
      </div>
    </div>
  </section>

  <section>
    <div class="container builder-layout">
      <div class="panel">
        <div class="section-head" style="text-align:left; margin-bottom:0.9rem;">
          <h2>Persona builder</h2>
          <p>Fill out the fields to generate a placeholder persona preview. This is all front-end and easy to expand later.</p>
        </div>

        <div class="tab-row">
          <button class="tab active" type="button">🌸 Basics</button>
          <button class="tab" type="button">🎨 Style</button>
          <button class="tab" type="button">💬 Voice</button>
          <button class="tab" type="button">✨ Extras</button>
        </div>

        <div class="field">
          <label for="personaName">Persona name</label>
          <input id="personaName" type="text" value="Plumwave" placeholder="Enter a persona name">
        </div>

        <div class="field">
          <label for="personaHandle">Handle or username</label>
          <input id="personaHandle" type="text" value="@plumwave" placeholder="@yourhandle">
        </div>

        <div class="field">
          <label for="personaRole">Creator type or role</label>
          <input id="personaRole" type="text" value="Soft-tech creator" placeholder="Streamer, artist, designer, community lead...">
        </div>

        <div class="field">
          <label for="personaMood">Core mood words</label>
          <input id="personaMood" type="text" value="dreamy, kind, expressive, soft-tech" placeholder="dreamy, cozy, playful...">
        </div>

        <div class="field">
          <label for="personaAesthetic">Aesthetic direction</label>
          <select id="personaAesthetic">
            <option value="Pastel kawaii">Pastel kawaii</option>
            <option value="Soft dreamcore">Soft dreamcore</option>
            <option value="Cute cyber">Cute cyber</option>
            <option value="Velvet night">Velvet night</option>
            <option value="Hyperpop sparkle">Hyperpop sparkle</option>
          </select>
        </div>

        <div class="field">
          <label for="personaPalette">Colour palette</label>
          <select id="personaPalette">
            <option value="pink-lavender-mint-peach">Pink • Lavender • Mint • Peach</option>
            <option value="rose-lilac-cream">Rose • Lilac • Cream</option>
            <option value="berry-pink-violet">Berry • Pink • Violet</option>
            <option value="mint-sky-white">Mint • Sky • White</option>
            <option value="night-purple-silver">Night Purple • Silver</option>
          </select>
        </div>

        <div class="field">
          <label for="personaVoice">Voice and tone</label>
          <textarea id="personaVoice" placeholder="How should this persona sound?">Warm, playful, comforting, a little dreamy, and easy to connect with.</textarea>
        </div>

        <div class="field">
          <label for="personaBio">Short bio</label>
          <textarea id="personaBio" placeholder="Write a short persona bio">A cozy internet persona built around soft visuals, expressive creativity, and a welcoming online presence.</textarea>
        </div>

        <div class="field">
          <label for="personaPlatforms">Main platforms</label>
          <input id="personaPlatforms" type="text" value="TikTok, YouTube, Discord, Instagram" placeholder="TikTok, Twitch, Discord...">
          <div class="chip-row">
            <span class="chip">Creator-ready</span>
            <span class="chip">Profile-focused</span>
            <span class="chip">Glow-up friendly</span>
          </div>
        </div>

        <div class="button-row">
          <button id="generateBtn" class="btn btn-primary" type="button">Generate Persona Preview</button>
          <button id="resetBtn" class="btn btn-secondary" type="button">Reset Demo Values</button>
        </div>
      </div>

      <aside class="preview-card">
        <h3>Live persona preview</h3>
        <p>This panel updates with a simple placeholder persona card based on the builder fields.</p>

        <div class="preview-banner">
          <div class="preview-name" id="previewName">Plumwave</div>
          <div class="preview-handle" id="previewHandle">@plumwave · Soft-tech creator</div>
          <div class="chip-row" id="previewMoodChips">
            <span class="chip">dreamy</span>
            <span class="chip">kind</span>
            <span class="chip">expressive</span>
            <span class="chip">soft-tech</span>
          </div>
        </div>

        <div class="result-box">
          <div class="result-label">Aesthetic</div>
          <div class="result-line" id="previewAesthetic">Pastel kawaii</div>
        </div>

        <div class="result-box">
          <div class="result-label">Voice</div>
          <div class="result-line" id="previewVoice">Warm, playful, comforting, a little dreamy, and easy to connect with.</div>
        </div>

        <div class="result-box">
          <div class="result-label">Bio</div>
          <div class="result-line" id="previewBio">A cozy internet persona built around soft visuals, expressive creativity, and a welcoming online presence.</div>
        </div>

        <div class="result-box">
          <div class="result-label">Platforms</div>
          <div class="result-line" id="previewPlatforms">TikTok, YouTube, Discord, Instagram</div>
        </div>

        <div class="result-box">
          <div class="result-label">Palette</div>
          <div class="palette-row" id="previewPalette">
            <span class="swatch" style="background:#ff9ecf"></span>
            <span class="swatch" style="background:#d8c4ff"></span>
            <span class="swatch" style="background:#ccf5e7"></span>
            <span class="swatch" style="background:#ffe1cc"></span>
          </div>
        </div>

        <div class="tiny-note">Everything here is placeholder-ready, so you can later connect it to a real quiz, form, or profile system.</div>
      </aside>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
