  <script>
    const stats = [
      { id: 'stat-traits', value: 16, suffix: '+' },
      { id: 'stat-systems', value: 8, suffix: '' },
      { id: 'stat-ideas', value: 24, suffix: '+' }
    ];

    const paletteMap = {
      'pink-lavender-mint-peach': ['#ff9ecf', '#d8c4ff', '#ccf5e7', '#ffe1cc'],
      'rose-lilac-cream': ['#ffb4d9', '#dcbcff', '#fff1da', '#fffdf8'],
      'berry-pink-violet': ['#cc4b8e', '#ff7bc3', '#9e7bff', '#f6d7ff'],
      'mint-sky-white': ['#b8f3df', '#bfe7ff', '#ffffff', '#e8fff8'],
      'night-purple-silver': ['#5d4f91', '#8f7cff', '#c6c6dd', '#f2f2fb']
    };

    const defaults = {
      name: 'Plumwave',
      handle: '@plumwave',
      role: 'Soft-tech creator',
      mood: 'dreamy, kind, expressive, soft-tech',
      aesthetic: 'Pastel kawaii',
      palette: 'pink-lavender-mint-peach',
      voice: 'Warm, playful, comforting, a little dreamy, and easy to connect with.',
      bio: 'A cozy internet persona built around soft visuals, expressive creativity, and a welcoming online presence.',
      platforms: 'TikTok, YouTube, Discord, Instagram'
    };

    function animateCount(element, target, suffix = '') {
      let current = 0;
      const duration = 1200;
      const stepTime = 20;
      const steps = duration / stepTime;
      const increment = target / steps;

      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        element.textContent = Math.round(current) + suffix;
      }, stepTime);
    }

    function setPalette(colors) {
      const palette = document.getElementById('previewPalette');
      palette.innerHTML = '';
      colors.forEach(color => {
        const swatch = document.createElement('span');
        swatch.className = 'swatch';
        swatch.style.background = color;
        palette.appendChild(swatch);
      });
    }

    function setMoodChips(moods) {
      const container = document.getElementById('previewMoodChips');
      container.innerHTML = '';
      moods.forEach(mood => {
        const chip = document.createElement('span');
        chip.className = 'chip';
        chip.textContent = mood.trim();
        container.appendChild(chip);
      });
    }

    function updatePreview() {
      const name = document.getElementById('personaName').value.trim() || defaults.name;
      const handle = document.getElementById('personaHandle').value.trim() || defaults.handle;
      const role = document.getElementById('personaRole').value.trim() || defaults.role;
      const mood = document.getElementById('personaMood').value.trim() || defaults.mood;
      const aesthetic = document.getElementById('personaAesthetic').value;
      const paletteKey = document.getElementById('personaPalette').value;
      const voice = document.getElementById('personaVoice').value.trim() || defaults.voice;
      const bio = document.getElementById('personaBio').value.trim() || defaults.bio;
      const platforms = document.getElementById('personaPlatforms').value.trim() || defaults.platforms;

      document.getElementById('previewName').textContent = name;
      document.getElementById('previewHandle').textContent = `${handle} · ${role}`;
      document.getElementById('previewAesthetic').textContent = aesthetic;
      document.getElementById('previewVoice').textContent = voice;
      document.getElementById('previewBio').textContent = bio;
      document.getElementById('previewPlatforms').textContent = platforms;
      document.getElementById('heroPersonaName').textContent = name;
      document.getElementById('heroPersonaMood').textContent = mood.replaceAll(',', ' •');

      setMoodChips(mood.split(','));
      setPalette(paletteMap[paletteKey] || paletteMap[defaults.palette]);
    }

    function resetDemo() {
      document.getElementById('personaName').value = defaults.name;
      document.getElementById('personaHandle').value = defaults.handle;
      document.getElementById('personaRole').value = defaults.role;
      document.getElementById('personaMood').value = defaults.mood;
      document.getElementById('personaAesthetic').value = defaults.aesthetic;
      document.getElementById('personaPalette').value = defaults.palette;
      document.getElementById('personaVoice').value = defaults.voice;
      document.getElementById('personaBio').value = defaults.bio;
      document.getElementById('personaPlatforms').value = defaults.platforms;
      updatePreview();
    }

    window.addEventListener('DOMContentLoaded', () => {
      document.getElementById('year').textContent = new Date().getFullYear();

      stats.forEach(stat => {
        const el = document.getElementById(stat.id);
        if (el) animateCount(el, stat.value, stat.suffix);
      });

      document.getElementById('generateBtn').addEventListener('click', updatePreview);
      document.getElementById('resetBtn').addEventListener('click', resetDemo);

      ['personaName', 'personaHandle', 'personaRole', 'personaMood', 'personaAesthetic', 'personaPalette', 'personaVoice', 'personaBio', 'personaPlatforms']
        .forEach(id => {
          document.getElementById(id).addEventListener('input', updatePreview);
          document.getElementById(id).addEventListener('change', updatePreview);
        });

      updatePreview();
    });
  </script>
